he following function:\n\n```javascript\nreturn data.applications.flatMap(app => [\n  {name: app.name,group: \"Priority 1\",value: Number(app.priority_1_findings) || 0},\n  {name: app.name,group: \"Priority 2\",value: Number(app.priority_2_findings) || 0},\n  {name: app.name,group: \"Priority 3\",value: Number(app.priority_3_findings) || 0}])\n```\nThis converts each application into multiple rows, one per priority. Making it compatible with grouped or stacked visualizations.","valueMapping":[],"widgetId":"1766da81-a201-4013-a0e2-9c29d14b15e6"}],"gridItem":{"id":"692d4f20-b95d-4e8b-a501-9d22cb188855","createdAt":"2026-03-31T14:15:10.601Z","desktop":{"h":47,"w":6,"x":5,"y":44},"mobile":{"h":4,"w":12,"x":0,"y":28},"showInDesktop":true,"showInMobile":true,"updatedAt":"2026-03-31T16:17:06.687Z","widgetId":"1766da81-a201-4013-a0e2-9c29d14b15e6"}}]}],"resourceStates":[],"exportVersion":1}